<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══════════ TAB BAR ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@color/design_default_color_primary"
            android:elevation="4dp">

            <Button
                android:id="@+id/btnTabLive"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🎤 Live Translate"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackground"
                android:textSize="13sp"/>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#FFFFFF44"/>

            <Button
                android:id="@+id/btnTabRecordings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🎙 Recordings"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackground"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- ════════════════════════════════════════════
             LIVE TAB
             ════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutLive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ── Controls card ──────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Row: Listen / REC badge / Export -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Switch
                            android:id="@+id/switchListen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎤 Listen"/>

                        <TextView
                            android:id="@+id/tvListeningBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="● REC"
                            android:textColor="#E53935"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="gone"/>

                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnExport"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Export"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Row: Continuous / AI / Auto-speak -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <Switch
                            android:id="@+id/switchContinuous"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Continuous"/>

                        <Switch
                            android:id="@+id/switchAiReplies"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="AI replies"/>

                        <Switch
                            android:id="@+id/switchAutoSpeak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Auto-speak"/>
                    </LinearLayout>

                    <!-- Row: AI reply language -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI reply lang:"
                            android:textSize="13sp"/>

                        <RadioGroup
                            android:id="@+id/rgAiLang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginStart="8dp">

                            <RadioButton
                                android:id="@+id/rbAiSource"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Source"
                                android:textSize="13sp"/>

                            <RadioButton
                                android:id="@+id/rbAiTarget"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Target"
                                android:textSize="13sp"
                                android:checked="true"
                                android:layout_marginStart="8dp"/>
                        </RadioGroup>
                    </LinearLayout>


                    <!-- Row: TTS speak speed -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔊 Speed:"
                            android:textSize="13sp"
                            android:minWidth="68dp"/>

                        <SeekBar
                            android:id="@+id/seekTtsSpeed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="33"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tvTtsSpeedLabel"
                            android:layout_width="42dp"
                            android:layout_height="wrap_content"
                            android:text="1.0x"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:gravity="end"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#E0E0E0" android:layout_marginVertical="10dp"/>

                    <!-- Row: API key -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvKeyStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="API key: not set"
                            android:textSize="12sp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPickApiKeyFile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Set key"
                            android:textSize="12sp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearApiKey"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clear"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#E0E0E0" android:layout_marginVertical="10dp"/>

                    <!-- Row: Language pickers + swap -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="From" android:textStyle="bold" android:textSize="12sp"/>
                            <Spinner android:id="@+id/spinnerSource"
                                android:layout_width="match_parent" android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSwapLanguages"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⇄"
                            android:textSize="20sp"
                            android:minWidth="0dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="To" android:textStyle="bold" android:textSize="12sp"/>
                            <Spinner android:id="@+id/spinnerTarget"
                                android:layout_width="match_parent" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Continuous mode card (hidden by default) ───────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardContinuous"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#1565C0"
                app:strokeWidth="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Continuous transcription"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#1565C0"/>

                    <!-- Live partial / accumulating text -->
                    <TextView
                        android:id="@+id/tvContinuousLive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="15sp"
                        android:textColor="#424242"
                        android:hint="Speech will appear here…"
                        android:minHeight="60dp"
                        android:gravity="top"/>

                    <!-- Auto-translated output -->
                    <TextView
                        android:id="@+id/tvContinuousFinal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="15sp"
                        android:textColor="#1565C0"
                        android:hint="Translation will appear here…"
                        android:minHeight="40dp"
                        android:gravity="top"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFinalizeTranslate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Add to History"
                            android:textSize="13sp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearContinuous"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Clear"
                            android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Manual input card ──────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Type or dictate text to translate…">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etManualText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:imeOptions="actionDone"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTranslate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Translate"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── History header ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:paddingStart="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Translation history"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearHistory"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear all"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- ── Translation history list ──────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout><!-- end layoutLive -->

        <!-- ════════════════════════════════════════════
             RECORDINGS TAB
             ════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutRecordings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <!-- Record button card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRecordToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏺ Start recording"
                        android:textSize="16sp"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"/>

                    <TextView
                        android:id="@+id/tvRecordStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#E53935"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:text=""
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recordings list header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingStart="4dp"
                android:text="Saved recordings"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <!-- Recordings list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecordings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout><!-- end layoutRecordings -->

    </LinearLayout>
</ScrollView>
