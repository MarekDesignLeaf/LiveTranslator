<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Name + size row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvRecName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="14sp"
                android:text=""/>

            <TextView
                android:id="@+id/tvRecSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:text=""/>
        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/tvRecDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_marginTop="2dp"
            android:text=""/>

        <!-- Transcription (hidden if empty) -->
        <TextView
            android:id="@+id/tvRecTranscript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:textColor="#212121"
            android:text=""
            android:visibility="gone"/>

        <!-- Translation (hidden if empty) -->
        <TextView
            android:id="@+id/tvRecTranslation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="14sp"
            android:textColor="#1565C0"
            android:text=""
            android:visibility="gone"/>

        <!-- Action buttons -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRecPlay"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶ Play"
                    android:textSize="12sp"
                    android:minHeight="36dp"
                    android:minWidth="0dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRecTranscribe"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Transcribe + Translate"
                    android:textSize="12sp"
                    android:minHeight="36dp"
                    android:minWidth="0dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRecDelete"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="🗑"
                    android:textSize="16sp"
                    android:minHeight="36dp"
                    android:minWidth="0dp"/>

            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
